<Page
    x:Class="RyTuneX.Views.PackagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:RyTuneX.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

	<Page.Resources>
		<Style x:Key="PackageItemContainerStyle" TargetType="ListViewItem">
			<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
			<Setter Property="IsEnabled" Value="{Binding ItemIsEnabled}"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Margin" Value="0,0,0,3"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ListViewItem">
						<Grid>
							<VisualStateManager.VisualStateGroups>
								<VisualStateGroup x:Name="CommonStates">
									<VisualState x:Name="Normal"/>
									<VisualState x:Name="PointerOver">
										<VisualState.Setters>
											<Setter Target="CardBorder.Background"
													Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
										</VisualState.Setters>
									</VisualState>
									<VisualState x:Name="Pressed">
										<VisualState.Setters>
											<Setter Target="CardBorder.Background"
													Value="{ThemeResource CardBackgroundFillColorTertiaryBrush}"/>
										</VisualState.Setters>
									</VisualState>
									<VisualState x:Name="Disabled"/>
								</VisualStateGroup>
								<VisualStateGroup x:Name="SelectionStates">
									<VisualState x:Name="Unselected"/>
									<VisualState x:Name="Selected">
										<VisualState.Setters>
											<Setter Target="CardBorder.Background"
													Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
											<Setter Target="ItemCheckBox.IsChecked" Value="True"/>
										</VisualState.Setters>
									</VisualState>
									<VisualState x:Name="SelectedSingleOrMultiple">
										<VisualState.Setters>
											<Setter Target="CardBorder.Background"
													Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
											<Setter Target="ItemCheckBox.IsChecked" Value="True"/>
										</VisualState.Setters>
									</VisualState>
								</VisualStateGroup>
							</VisualStateManager.VisualStateGroups>

							<Border x:Name="CardBorder"
									Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
									BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
									BorderThickness="1"
									CornerRadius="6"
									Padding="12,10"
									Opacity="{Binding ItemOpacity}">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="*"/>
									</Grid.ColumnDefinitions>
									<CheckBox x:Name="ItemCheckBox"
											  Grid.Column="0"
											  VerticalAlignment="Center"
											  Margin="0,0,8,0"
											  MinWidth="0"
											  IsHitTestVisible="False"
											  IsTabStop="False"
											  IsChecked="{TemplateBinding IsSelected}"/>
									<ContentPresenter Grid.Column="1"
													  HorizontalAlignment="Stretch"/>
								</Grid>
							</Border>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<DataTemplate x:Key="PackageItemTemplate" x:DataType="models:WingetPackage">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="2*"/>
					<ColumnDefinition Width="1.7*"/>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="1.2*"/>
				</Grid.ColumnDefinitions>

				<!-- Name -->
				<StackPanel Grid.Column="0"
							Orientation="Horizontal"
							Spacing="8"
							VerticalAlignment="Center">
					<FontIcon Glyph="&#xE7B8;" FontSize="14" Opacity="0.85"/>
					<TextBlock Text="{x:Bind Name, Mode=OneWay}"
							   FontWeight="SemiBold"
							   FontSize="13"
							   VerticalAlignment="Center"
							   TextTrimming="CharacterEllipsis"/>
				</StackPanel>

				<!-- Package ID -->
				<StackPanel Grid.Column="1"
							Orientation="Horizontal"
							Spacing="8"
							VerticalAlignment="Center">
					<FontIcon Glyph="&#xE8A5;" FontSize="13" Opacity="0.75"/>
					<TextBlock Text="{x:Bind Id}"
							   FontSize="13"
							   VerticalAlignment="Center"
							   TextTrimming="CharacterEllipsis"
							   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
				</StackPanel>

				<!-- Version column — three mutually exclusive states -->
				<StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">

					<!-- Not installed — show available version -->
					<StackPanel Orientation="Horizontal"
								Spacing="4"
								Visibility="{x:Bind NotInstalledVisibility, Mode=OneWay}">
						<FontIcon Glyph="&#xE896;" FontSize="13" Opacity="0.75"/>
						<TextBlock Text="{x:Bind Version, Mode=OneWay}"
								   FontSize="13"
								   VerticalAlignment="Center"/>
					</StackPanel>

					<!-- Installed, no update pending -->
					<StackPanel Orientation="Horizontal"
								Spacing="4"
								Visibility="{x:Bind InstalledNoUpdateVisibility, Mode=OneWay}">
						<FontIcon Glyph="&#xE73E;"
								  FontSize="12"
								  Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
						<TextBlock Text="Installed"
								   FontSize="12"
								   VerticalAlignment="Center"
								   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
					</StackPanel>

					<!-- Update available — show new version -->
					<StackPanel Orientation="Horizontal"
								Spacing="4"
								Visibility="{x:Bind UpdateVisibility, Mode=OneWay}">
						<FontIcon Glyph="&#xE898;"
								  FontSize="12"
								  Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
						<TextBlock Text="{x:Bind LatestVersion, Mode=OneWay}"
								   FontSize="12"
								   VerticalAlignment="Center"
								   Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
					</StackPanel>

				</StackPanel>

				<!-- Publisher -->
				<StackPanel Grid.Column="3"
							Orientation="Horizontal"
							Spacing="8"
							VerticalAlignment="Center">
					<FontIcon Glyph="&#xE71D;" FontSize="13" Opacity="0.75"/>
					<TextBlock Text="{x:Bind Category}"
							   FontSize="13"
							   VerticalAlignment="Center"
							   TextTrimming="CharacterEllipsis"/>
				</StackPanel>
			</Grid>
		</DataTemplate>
	</Page.Resources>

	<Grid Padding="24,14,24,0">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Grid Grid.Row="0" Margin="0,0,0,12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<!-- Tab pill strip -->
			<controls:Segmented x:Name="TabSegmented"
								Grid.Column="0"
								Margin="0,0,10,0"
								VerticalAlignment="Center"
								SelectionChanged="TabSegmented_SelectionChanged"
								SelectedIndex="0">
				<controls:SegmentedItem Content="Browse" />
				<controls:SegmentedItem x:Name="UpdatesTabItem">
					<TextBlock x:Name="UpdatesTabLabel" Text="Updates" Margin="4,0"/>
				</controls:SegmentedItem>
			</controls:Segmented>

			<!-- Search box -->
			<AutoSuggestBox x:Name="PackageSearchBox"
							Grid.Column="1"
							HorizontalAlignment="Stretch"
							MinWidth="80"
							Height="34"
							QueryIcon="Find"
							PlaceholderText="Search all winget packages..."
							Margin="0,0,10,0"
							TextChanged="PackageSearchBox_TextChanged"
							QuerySubmitted="PackageSearchBox_QuerySubmitted"/>

			<!-- Action buttons -->
			<controls:WrapPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

				<Button x:Name="InstallButton"
                        Margin="0,0,8,0"
                        Click="InstallSelectedApp_Click"
                        Style="{ThemeResource AccentButtonStyle}">
					<StackPanel Orientation="Horizontal" Spacing="8">
						<FontIcon x:Name="InstallButtonIcon" Glyph="&#xE896;" FontSize="16"/>
						<TextBlock x:Name="InstallButtonText" Text="Install Selected"/>
					</StackPanel>
				</Button>

				<Button x:Name="RefreshButton"
                        Click="RefreshButton_Click"
                        Padding="10,7"
                        MinWidth="0"
                        MinHeight="0">
					<FontIcon Glyph="&#xE72C;" FontSize="13"/>
				</Button>
			</controls:WrapPanel>
		</Grid>

		<!-- Column header + ListView -->
		<Grid Grid.Row="1" Margin="0,0,0,24">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Column header bar -->
			<Border Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="46,10,16,10"
                    Margin="0,0,0,8">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="2*"/>
						<ColumnDefinition Width="1.7*"/>
						<ColumnDefinition Width="1*"/>
						<ColumnDefinition Width="1.2*"/>
					</Grid.ColumnDefinitions>
					<TextBlock Text="Package Name" FontWeight="SemiBold"/>
					<TextBlock Grid.Column="1" Text="Package ID" FontWeight="SemiBold"/>
					<TextBlock Grid.Column="2" Text="Version" FontWeight="SemiBold"/>
					<TextBlock Grid.Column="3" Text="Publisher" FontWeight="SemiBold"/>
				</Grid>
			</Border>

			<!-- Package list area -->
			<Grid Grid.Row="1">
				<!-- Loading spinner -->
				<StackPanel x:Name="LoadingState" VerticalAlignment="Center" Visibility="Visible">
					<ProgressRing Margin="20" Width="100" Height="100" IsIndeterminate="True"/>
					<TextBlock Text="Loading packages…"
							   Style="{StaticResource DetailBodyBaseMediumStyle}"
							   HorizontalAlignment="Center"/>
				</StackPanel>

				<!-- Package list -->
				<ListView x:Name="PackagesGridView"
						  ItemsSource="{x:Bind PackageList}"
						  SelectionMode="Multiple"
						  SelectionChanged="PackagesGridView_SelectionChanged"
						  Visibility="Collapsed"
						  ItemContainerStyle="{StaticResource PackageItemContainerStyle}"
						  ItemTemplate="{StaticResource PackageItemTemplate}">
					<ListView.ItemContainerTransitions>
						<TransitionCollection>
							<EntranceThemeTransition FromVerticalOffset="24"/>
							<RepositionThemeTransition IsStaggeringEnabled="False"/>
						</TransitionCollection>
					</ListView.ItemContainerTransitions>
				</ListView>

				<!-- Updates list -->
				<ListView x:Name="UpdatesGridView"
						  ItemsSource="{x:Bind UpdatesList}"
						  SelectionMode="Multiple"
						  SelectionChanged="PackagesGridView_SelectionChanged"
						  Visibility="Collapsed"
						  ItemContainerStyle="{StaticResource PackageItemContainerStyle}"
						  ItemTemplate="{StaticResource PackageItemTemplate}">
					<ListView.ItemContainerTransitions>
						<TransitionCollection>
							<EntranceThemeTransition FromVerticalOffset="24"/>
							<RepositionThemeTransition IsStaggeringEnabled="False"/>
						</TransitionCollection>
					</ListView.ItemContainerTransitions>
				</ListView>

				<!-- Empty / error state -->
				<TextBlock x:Name="StatusText"
                           Style="{StaticResource DetailBodyBaseMediumStyle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Visibility="Collapsed"/>
			</Grid>
		</Grid>

		<!-- Progress bar -->
		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<TextBlock x:Name="installingStatusText"
                       Margin="12,6"
                       Grid.Column="0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Text="Select a package to install"
                       TextWrapping="Wrap"/>
			<ProgressBar x:Name="installingStatusBar"
                         Margin="0,0,12,0"
                         Grid.Column="1"
                         Width="Auto"
                         Minimum="0"
                         Maximum="100"
                         Opacity="0"/>
		</Grid>
	</Grid>
</Page>
