<Page
    x:Class="RyTuneX.Views.SystemInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d">

    <Grid>
        <StackPanel Grid.Row="1" x:Name="loadingProgressRing" VerticalAlignment="Center" Margin="0,40,0,0">
            <ProgressRing IsActive="True" Width="80" Height="80"/>
            <TextBlock x:Uid="Loading" HorizontalAlignment="Center" Margin="0,20,0,0" Style="{StaticResource DetailBodyBaseMediumStyle}"/>
        </StackPanel>
        <ScrollViewer x:Name="ContentArea" Padding="24,14,24,0" HorizontalScrollMode="Disabled" VerticalScrollMode="Auto" Visibility="Collapsed" Background="Transparent">
            <Grid Margin="0,0,0,38">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" x:Name="summaryPanel" Margin="0,0,0,24" Padding="24" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <FontIcon Glyph="&#xE7F8;" FontSize="56" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Name="DeviceNameText" Style="{StaticResource TitleTextBlockStyle}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock x:Name="DeviceSummaryText" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="6">
                    <StackPanel.ChildrenTransitions>
                        <EntranceThemeTransition FromVerticalOffset="50" />
                        <RepositionThemeTransition IsStaggeringEnabled="False" />
                    </StackPanel.ChildrenTransitions>

                    <!-- OS -->
                    <controls:SettingsExpander
                            IsExpanded="True"
                            Header="Operating System"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE958;}">

                        <Button Tag="os"
                                Padding="10,10"
                                Click="CopyExpander_Click">
                            <TextBlock Margin="20,-4" Text="Copy" />
                        </Button>

                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard HorizontalContentAlignment="Left"
                               ContentAlignment="Left">
                                <StackPanel Margin="0,16"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="os"
                                            TextWrapping="Wrap"
                                            Style="{ThemeResource BodyTextBlockStyle}" />
                                </StackPanel>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- CPU -->
                    <controls:SettingsExpander
                            IsExpanded="True"
                            Header="Processor"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE950;}">

                        <Button Tag="cpu"
                            Padding="10,10"
                            Click="CopyExpander_Click">
                            <TextBlock Margin="20,-4" Text="Copy" />
                        </Button>

                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard HorizontalContentAlignment="Left"
                               ContentAlignment="Left">
                                <StackPanel Margin="0,16"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="cpu"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource BodyTextBlockStyle}" />
                                </StackPanel>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- GPU -->
                    <controls:SettingsExpander
                            IsExpanded="True"
                            Header="Graphics"
                            HeaderIcon="{ui:FontIcon Glyph=&#xF211;}">

                        <Button Tag="gpu"
                                Padding="10,10"
                                Click="CopyExpander_Click">
                            <TextBlock Margin="20,-4" Text="Copy" />
                        </Button>

                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard HorizontalContentAlignment="Left"
                               ContentAlignment="Left">
                                <StackPanel Margin="0,16"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="gpu"
                                            TextWrapping="Wrap"
                                            Style="{ThemeResource BodyTextBlockStyle}" />
                                </StackPanel>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- RAM -->
                    <controls:SettingsExpander
                            IsExpanded="True"
                            Header="RAM"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE964;}">

                        <Button Tag="ram"
                                Padding="10,10"
                                Click="CopyExpander_Click">
                            <TextBlock Margin="20,-4" Text="Copy" />
                        </Button>

                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard HorizontalContentAlignment="Left"
                               ContentAlignment="Left">
                                <StackPanel Margin="0,16"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="ram"
                                            TextWrapping="Wrap"
                                            Style="{ThemeResource BodyTextBlockStyle}" />
                                </StackPanel>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- Storage -->
                    <controls:SettingsExpander
                            IsExpanded="True"
                            Header="Storage"
                            HeaderIcon="{ui:FontIcon Glyph=&#xEDA2;}">

                        <Button Tag="disk"
                                Padding="10,10"
                                Click="CopyExpander_Click">
                            <TextBlock Margin="20,-4" Text="Copy" />
                        </Button>

                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard HorizontalContentAlignment="Left"
                               ContentAlignment="Left">
                                <StackPanel Margin="0,16"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="disk"
                                            TextWrapping="Wrap"
                                            Style="{ThemeResource BodyTextBlockStyle}" />
                                </StackPanel>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- Network -->
                    <controls:SettingsExpander
                            IsExpanded="True"
                            Header="Network"
                            HeaderIcon="{ui:FontIcon Glyph=&#xEDA3;}">

                        <Button Tag="network"
                                Padding="10,10"
                                Click="CopyExpander_Click">
                            <TextBlock Margin="20,-4" Text="Copy" />
                        </Button>

                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard HorizontalContentAlignment="Left"
                               ContentAlignment="Left">
                                <StackPanel Margin="0,16"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="network"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource BodyTextBlockStyle}" />
                                </StackPanel>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- Battery -->
                    <controls:SettingsExpander
                            IsExpanded="True"
                            Header="Battery"
                            HeaderIcon="{ui:FontIcon Glyph=&#xF5F9;}">

                        <Button Tag="battery"
                                Padding="10,10"
                                Click="CopyExpander_Click">
                            <TextBlock Margin="20,-4" Text="Copy" />
                        </Button>

                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard HorizontalContentAlignment="Left"
                               ContentAlignment="Left">
                                <StackPanel Margin="0,16"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="battery"
                                            TextWrapping="Wrap"
                                            Style="{ThemeResource BodyTextBlockStyle}" />
                                </StackPanel>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                </StackPanel>
                
                <!-- Drivers -->
                <Border Grid.Row="2" Grid.ColumnSpan="2" Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Margin="0,24,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12" Height="40">
                            <FontIcon Glyph="&#xE8D5;" VerticalAlignment="Center"/>
                            <TextBlock x:Uid="SystemInfoPage_Drivers" Text="Drivers" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBox x:Uid="SystemInfoPage_FolderPathText" x:Name="FolderPathText" IsReadOnly="True" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,12"/>
                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <StackPanel x:Name="ExtractingStatus" Visibility="Collapsed" Orientation="Horizontal" Spacing="12">
                                <ProgressBar x:Name="ExtractingStatusPb" IsIndeterminate="True" Width="200" VerticalAlignment="Center"/>
                                <TextBlock x:Uid="SystemInfoPage_ExtractingStatusText" x:Name="ExtractingStatusText" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button x:Uid="SystemInfoPage_SelectButton" Content="Select" Click="SelectPathButton_Click" Margin="0"/>
                            <TextBlock Text="Drivers for Backup" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="6,0"/>
                            <Button x:Uid="SystemInfoPage_ExportButton" Content="Export" x:Name="ExtractButton" Click="ExtractButton_Click" Visibility="Visible"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>