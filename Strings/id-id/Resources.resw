  <data name="Feature_DisableSysMain.Description" xml:space="preserve">
    <value>Mematikan SysMain, yang memuat prapemuatan aplikasi yang sering digunakan agar startup lebih cepat. Mungkin berdampak pada waktu startup untuk beberapa program jika Anda menggunakan HDD.</value>
  </data>
  <data name="Feature_EnableGamingMode.Header" xml:space="preserve">
    <value>Aktifkan Gaming Mode</value>
  </data>
  <data name="Feature_EnableGamingMode.Description" xml:space="preserve">
    <value>Mengaktifkan Gaming Mode, yang mengoptimalkan sumber daya sistem untuk pengalaman bermain game yang lebih lancar. Mungkin memengaruhi proses di latar belakang.</value>
  </data>
  <data name="Feature_ExcludeDriversFromWindowsUpdates.Header" xml:space="preserve">
    <value>Kecualikan Driver Dari Pembaruan Windows</value>
  </data>
  <data name="Feature_ExcludeDriversFromWindowsUpdates.Description" xml:space="preserve">
    <value>Mengecualikan pembaruan driver dari Windows Update. Mungkin menyebabkan driver kedaluwarsa dengan potensi risiko keamanan atau masalah kompatibilitas. Gunakan dengan hati-hati.</value>
  </data>
  <data name="OptimizeAdvanced.Text" xml:space="preserve">
    <value>Optimisasi Lanjutan</value>
  </data>
  <data name="Feature_DisableSystemRestore.Header" xml:space="preserve">
    <value>Nonaktifkan System Restore</value>
  </data>
  <data name="Feature_DisableSystemRestore.Description" xml:space="preserve">
    <value>Menonaktifkan System Restore, yang membuat titik pemulihan untuk mengembalikan sistem ke keadaan sebelumnya jika terjadi masalah. Tidak direkomendasikan. Menonaktifkan fitur ini menghilangkan kemampuan untuk pulih dengan mudah dari potensi masalah sistem.</value>
  </data>
  <data name="Feature_DisableCortana.Header" xml:space="preserve">
    <value>Nonaktifkan Cortana</value>
  </data>
  <data name="Feature_DisableCortana.Description" xml:space="preserve">
    <value>Menonaktifkan Cortana, asisten virtual yang dapat menjawab pertanyaan dan menyelesaikan tugas. Mungkin berdampak pada pencarian suara dan beberapa fitur produktivitas.</value>
  </data>
  <data name="Feature_DisableStoreUpdates.Header" xml:space="preserve">
    <value>Nonaktifkan Pembaruan Store</value>
  </data>
  <data name="Feature_DisableStoreUpdates.Description" xml:space="preserve">
    <value>Menonaktifkan pembaruan otomatis untuk aplikasi yang diunduh dari Microsoft Store. Mungkin membuat aplikasi rentan terhadap risiko keamanan atau kehilangan fitur baru.</value>
  </data>
  <data name="Privacy_Telemetry.Text" xml:space="preserve">
    <value>Telemetri</value>
  </data>
  <data name="Feature_EnhancePrivacy.Header" xml:space="preserve">
    <value>Tingkatkan Privasi</value>
  </data>
  <data name="Feature_DisableSMBv1.Header" xml:space="preserve">
    <value>Nonaktifkan SMBv1</value>
  </data>
  <data name="Feature_DisableSMBv1.Description" xml:space="preserve">
    <value>Menonaktifkan Server Message Block versi 1 (SMBv1) untuk peningkatan keamanan. Direkomendasikan</value>
  </data>
  <data name="Feature_DisableSMBv2.Header" xml:space="preserve">
    <value>Nonaktifkan SMBv2</value>
  </data>
  <data name="Feature_DisableSMBv2.Description" xml:space="preserve">
    <value>Menonaktifkan Server Message Block versi 2 (SMBv2) untuk peningkatan keamanan. Gunakan dengan hati-hati karena mungkin merusak fungsionalitas berbagi file jaringan.</value>
  </data>
  <data name="Feature_DisableTelemetryServices.Header" xml:space="preserve">
    <value>Nonaktifkan Layanan Telemetri</value>
  </data>
  <data name="Feature_DisableTelemetryServices.Description" xml:space="preserve">
    <value>Mematikan layanan telemetri untuk mencegah pengumpulan dan transmisi data penggunaan oleh sistem operasi.</value>
  </data>
  <data name="Feature_DisableEdgeTelemetry.Header" xml:space="preserve">
